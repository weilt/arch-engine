{
  "embedding": {
    "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "apiKeyEnv": "DASHSCOPE_API_KEY",
    "model": "text-embedding-v3"
  },
  "chunking": {
    "baseUrl": "https://your-maas-endpoint/v1",
    "apiKeyEnv": "XF_MAAS_API_KEY",
    "chatModel": "astron-code-latest",
    "maxChunkTokens": 8000,
    "strategy": "semantic-only",
    "summarizeBatchSize": 8,
    "summarizeMaxRetries": 3,
    "summarizeRetryBaseDelayMs": 1000,
    "maxSignaturesPerCandidate": 12,
    "summarizeMaxTokens": 4096,
    "summarizeBatchDelayMs": 300,
    "summarizeJsonMode": false
  },
  "apiSpecGlobs": [
    "docs/**/*.json",
    "**/openapi.json",
    "**/swagger.json",
    "**/swagger.yaml",
    "**/apifox/**/*.json",
    "apifox-export/**/*.json"
  ],
  "scanners": {
    "java": true,
    "frontend": true
  },
  "designSystemPackages": [
    "@*/ui",
    "@org/design-system"
  ]
}
